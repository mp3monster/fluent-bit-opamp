{
  "consumer": {
    "server_url": "http://localhost:4320",
    "client_status_port": 2020,
    "chat_ops_port": 8888,
    "transport": "http",
    "tls": {
      "verify_server": true
    },
    "server-authorization": "none",
    "log_agent_api_responses": true,
    "agent_config_path": "./consumer/fluentd.conf",
    "agent_additional_params": ["-v"],
    "heartbeat_frequency": 30,
    "full_update_controller": {
      "fullResendAfter": 2
    },
    "full_update_controller_type": "SentCount",
    "allow_custom_capabilities": true,
    "log_level": "debug",
    "service_name": "Fluentd",
    "service_namespace": "FluentdNS"
  }
}
